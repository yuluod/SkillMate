{
  "name": "skillmate",
  "version": "0.0.4",
  "description": "AI Coding Assistant Skill Manager",
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=22.13.0",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "11.6.0",
      "onFail": "error"
    }
  },
  "scripts": {
    "tauri": "tauri",
    "frontend:dev": "vite --host --port 1420",
    "frontend:build": "vite build",
    "frontend:test:pure": "node --test src/lib/*.test.mjs",
    "frontend:test:ui": "vitest run",
    "frontend:test": "pnpm frontend:test:pure && pnpm frontend:test:ui",
    "rust:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test": "pnpm frontend:test && pnpm rust:test",
    "dev": "tauri dev",
    "build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "29.1.1",
    "vite": "^8.0.16",
    "vitest": "4.1.10"
  }
}
